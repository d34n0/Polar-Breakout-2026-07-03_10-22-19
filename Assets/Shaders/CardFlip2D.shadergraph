            "m_Id": "cf000000000000000000000000000007"
        },
        {
            "m_Id": "cf000000000000000000000000000008"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "CardFlipWarp",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float radX = radians(RotationAngle);\nfloat radY = radians(RotationAngleY);\nfloat squashX = cos(radX);\nfloat squashY = cos(radY);\nfloat warpY = 1.0 - SkewAmount * sin(radX) * Position.x * Position.x;\nfloat warpX = 1.0 - SkewAmountY * sin(radY) * Position.y * Position.y;\nWarpedPosition = float3(Position.x * squashX * warpX, Position.y * squashY * warpY, Position.z);"
}

